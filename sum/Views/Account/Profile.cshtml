@model sum.Models.User
@{
    ViewData["Title"] = "Profil";
}

<div class="profile-page">
    <div class="profile-card animate-in">
        <div class="profile-header">
            <div class="profile-avatar">
                <i class="fas fa-user-graduate"></i>
            </div>
        </div>
        <div class="profile-body">
            <div class="profile-name">
                <h1>@(Model.FullName ?? Model.Email)</h1>
                <div class="role-badge">
                    <i class="fas fa-shield-alt"></i>
                    @Model.Role
                </div>
            </div>

            <div class="profile-info-grid">
                <div class="profile-info-item">
                    <div class="profile-info-icon" style="background: #d1fae5; color: #065f46;">
                        <i class="fas fa-envelope"></i>
                    </div>
                    <div class="profile-info-text">
                        <div class="info-label">E-mail</div>
                        <div class="info-value">@Model.Email</div>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.FullName))
                {
                    <div class="profile-info-item">
                        <div class="profile-info-icon" style="background: #ede9fe; color: #5b21b6;">
                            <i class="fas fa-id-card"></i>
                        </div>
                        <div class="profile-info-text">
                            <div class="info-label">Celé jméno</div>
                            <div class="info-value">@Model.FullName</div>
                        </div>
                    </div>
                }

                <div class="profile-info-item">
                    <div class="profile-info-icon" style="background: #fef3c7; color: #92400e;">
                        <i class="fas fa-calendar"></i>
                    </div>
                    <div class="profile-info-text">
                        <div class="info-label">Registrace</div>
                        <div class="info-value">@Model.CreatedAt.ToString("d. MMMM yyyy", new System.Globalization.CultureInfo("cs-CZ"))</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
