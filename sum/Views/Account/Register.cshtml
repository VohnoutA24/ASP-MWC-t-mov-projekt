@model sum.Models.RegisterViewModel
@{
    ViewData["Title"] = "Registrace";
}

<div class="auth-page">
    <div class="auth-container">
        <div class="auth-card animate-in">
            <div class="auth-header">
                <div class="auth-icon">
                    <i class="fas fa-user-plus"></i>
                </div>
                <h1>Registrace</h1>
                <p>Vytvořte si svůj školní účet</p>
            </div>

            <form asp-action="Register" asp-controller="Account" method="post" id="registerForm">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

                <div class="form-group">
                    <label asp-for="Username">Uživatelské jméno <span class="required">*</span></label>
                    <div class="form-input-wrapper">
                        <input asp-for="Username" class="form-input" id="registerUsername" placeholder="Zvolte si přezdívku" autocomplete="username" />
                        <i class="fas fa-user input-icon"></i>
                    </div>
                    <span asp-validation-for="Username" class="field-validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="FullName">Celé jméno</label>
                    <div class="form-input-wrapper">
                        <input asp-for="FullName" class="form-input" id="registerFullName" placeholder="Jan Novák" autocomplete="name" />
                        <i class="fas fa-id-card input-icon"></i>
                    </div>
                    <span asp-validation-for="FullName" class="field-validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Email">E-mail <span class="required">*</span></label>
                    <div class="form-input-wrapper">
                        <input asp-for="Email" class="form-input" id="registerEmail" placeholder="vas@email.cz" autocomplete="email" />
                        <i class="fas fa-envelope input-icon"></i>
                    </div>
                    <span asp-validation-for="Email" class="field-validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Password">Heslo <span class="required">*</span></label>
                    <div class="form-input-wrapper">
                        <input asp-for="Password" class="form-input" id="registerPassword" placeholder="Alespoň 6 znaků" autocomplete="new-password" />
                        <i class="fas fa-lock input-icon"></i>
                    </div>
                    <span asp-validation-for="Password" class="field-validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ConfirmPassword">Potvrzení hesla <span class="required">*</span></label>
                    <div class="form-input-wrapper">
                        <input asp-for="ConfirmPassword" class="form-input" id="registerConfirmPassword" placeholder="Zopakujte heslo" autocomplete="new-password" />
                        <i class="fas fa-shield-alt input-icon"></i>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>
                </div>

                <button type="submit" class="btn-auth" id="registerSubmitBtn" style="margin-top: 0.5rem;">
                    <i class="fas fa-user-plus"></i> Vytvořit účet
                </button>
            </form>

            <div class="auth-footer">
                <p>Již máte účet? <a asp-controller="Account" asp-action="Login" id="goToLoginLink">Přihlaste se</a></p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
