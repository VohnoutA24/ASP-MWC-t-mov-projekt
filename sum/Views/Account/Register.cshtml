@model sum.Models.RegisterViewModel
@{
    ViewData["Title"] = "Registrace";
}

<div class="auth-page">
    <div class="auth-container">
        <div class="auth-card animate-in">
            <div class="auth-header">
                <div class="auth-icon-img">
                    <img src="~/images/user-login.svg" alt="Registrace" class="auth-svg" />
                </div>
                <h1>Registrace</h1>
                <p>Základní škola Chvalkovice</p>
            </div>

            <div class="auth-domain-notice">
                <i class="fas fa-info-circle"></i>
                Registrace je povolena pouze pro školní e-maily <strong>@("@zschvalk.cz")</strong>
            </div>

            <form asp-action="Register" asp-controller="Account" method="post" id="registerForm">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

                <div class="form-group">
                    <label asp-for="Email">E-mail <span class="required">*</span></label>
                    <div class="form-input-wrapper">
                        <input asp-for="Email" class="form-input" id="registerEmail" placeholder="vas.jmeno@zschvalk.cz" autocomplete="email" />
                        <i class="fas fa-envelope input-icon"></i>
                    </div>
                    <span asp-validation-for="Email" class="field-validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Password">Heslo <span class="required">*</span></label>
                    <div class="form-input-wrapper">
                        <input asp-for="Password" class="form-input" id="registerPassword" placeholder="Alespoň 6 znaků" autocomplete="new-password" />
                        <i class="fas fa-lock input-icon"></i>
                    </div>
                    <span asp-validation-for="Password" class="field-validation-error"></span>
                </div>

                <button type="submit" class="btn-auth" id="registerSubmitBtn" style="margin-top: 0.5rem;">
                    <i class="fas fa-user-plus"></i> Vytvořit účet
                </button>
            </form>

            <div class="auth-footer">
                <p>Již máte účet? <a asp-controller="Account" asp-action="Login" id="goToLoginLink">Přihlaste se</a></p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
