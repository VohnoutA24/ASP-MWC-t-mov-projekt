@section Scripts {
    <script>
        (function () {
            const days = document.querySelectorAll('.timetable-day');
            const dots = document.querySelectorAll('.tt-dot');
            let current = new Date().getDay() - 1;
            if (current < 0 || current > 4) current = 0;

            function show(i) {
                current = Math.max(0, Math.min(4, i));
                days.forEach((d, idx) => {
                    d.classList.toggle('active', idx === current);
                });
                dots.forEach((d, idx) => {
                    d.classList.toggle('active', idx === current);
                });
            }

            dots.forEach(d => d.addEventListener('click', () => show(+d.dataset.day)));

            // Synchronize hover for double lessons
            document.querySelectorAll('.double-lesson-top, .double-lesson-bottom').forEach(row => {
                row.addEventListener('mouseenter', () => {
                    const parent = row.parentElement;
                    const rows = Array.from(parent.children);
                    const idx = rows.indexOf(row);
                    if (row.classList.contains('double-lesson-top')) {
                        rows[idx + 1]?.classList.add('hover-sync');
                    } else {
                        rows[idx - 1]?.classList.add('hover-sync');
                    }
                });
                row.addEventListener('mouseleave', () => {
                    const parent = row.parentElement;
                    Array.from(parent.children).forEach(r => r.classList.remove('hover-sync'));
                });
            });

            show(current);
        })();
    </script>
}
