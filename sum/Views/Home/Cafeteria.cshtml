@{
    ViewData["Title"] = "Jídelna";
}

<div class="cafeteria-page">
    <div class="cafeteria-header animate-in">
        <h1><i class="fas fa-utensils"></i> Školní jídelna</h1>
        <p>Základní škola Chvalkovice · Suterén budovy</p>
    </div>

    <div class="cafeteria-info animate-in">
        <div class="info-card">
            <i class="fas fa-clock"></i>
            <div>
                <strong>Výdej obědů</strong>
                <span>11:30 – 14:00</span>
            </div>
        </div>
        <div class="info-card">
            <i class="fas fa-map-marker-alt"></i>
            <div>
                <strong>Umístění</strong>
                <span>Suterén, místnost S01</span>
            </div>
        </div>
        <div class="info-card">
            <i class="fas fa-money-bill-wave"></i>
            <div>
                <strong>Cena oběda</strong>
                <span>32 Kč / den</span>
            </div>
        </div>
    </div>

    <div class="menu-week animate-in">
        <h2><i class="fas fa-list-alt"></i> Jídelníček na tento týden</h2>

        <div class="menu-day">
            <div class="menu-day-header">
                <span class="menu-day-name">Pondělí</span>
            </div>
            <div class="menu-day-body">
                <div class="menu-item">
                    <span class="menu-label">Polévka</span>
                    <span class="menu-food">Hovězí vývar s nudlemi</span>
                </div>
                <div class="menu-item">
                    <span class="menu-label">Oběd 1</span>
                    <span class="menu-food">Kuřecí řízek, bramborová kaše, okurkový salát</span>
                </div>
                <div class="menu-item">
                    <span class="menu-label">Oběd 2</span>
                    <span class="menu-food">Špagety s masovou omáčkou, sýr</span>
                </div>
            </div>
        </div>

        <div class="menu-day">
            <div class="menu-day-header">
                <span class="menu-day-name">Úterý</span>
            </div>
            <div class="menu-day-body">
                <div class="menu-item">
                    <span class="menu-label">Polévka</span>
                    <span class="menu-food">Bramboračka</span>
                </div>
                <div class="menu-item">
                    <span class="menu-label">Oběd 1</span>
                    <span class="menu-food">Svíčková na smetaně, houskové knedlíky</span>
                </div>
                <div class="menu-item">
                    <span class="menu-label">Oběd 2</span>
                    <span class="menu-food">Zeleninové rizoto se sýrem</span>
                </div>
            </div>
        </div>

        <div class="menu-day">
            <div class="menu-day-header">
                <span class="menu-day-name">Středa</span>
            </div>
            <div class="menu-day-body">
                <div class="menu-item">
                    <span class="menu-label">Polévka</span>
                    <span class="menu-food">Čočková polévka</span>
                </div>
                <div class="menu-item">
                    <span class="menu-label">Oběd 1</span>
                    <span class="menu-food">Vepřový guláš, houskové knedlíky</span>
                </div>
                <div class="menu-item">
                    <span class="menu-label">Oběd 2</span>
                    <span class="menu-food">Palačinky s tvarohem a jahodovou omáčkou</span>
                </div>
            </div>
        </div>

        <div class="menu-day">
            <div class="menu-day-header">
                <span class="menu-day-name">Čtvrtek</span>
            </div>
            <div class="menu-day-body">
                <div class="menu-item">
                    <span class="menu-label">Polévka</span>
                    <span class="menu-food">Rajská polévka s rýží</span>
                </div>
                <div class="menu-item">
                    <span class="menu-label">Oběd 1</span>
                    <span class="menu-food">Smažený sýr, hranolky, tatarská omáčka</span>
                </div>
                <div class="menu-item">
                    <span class="menu-label">Oběd 2</span>
                    <span class="menu-food">Kuřecí na paprice, těstoviny</span>
                </div>
            </div>
        </div>

        <div class="menu-day">
            <div class="menu-day-header">
                <span class="menu-day-name">Pátek</span>
            </div>
            <div class="menu-day-body">
                <div class="menu-item">
                    <span class="menu-label">Polévka</span>
                    <span class="menu-food">Zeleninový krém</span>
                </div>
                <div class="menu-item">
                    <span class="menu-label">Oběd 1</span>
                    <span class="menu-food">Rybí filé, brambor, zeleninový salát</span>
                </div>
                <div class="menu-item">
                    <span class="menu-label">Oběd 2</span>
                    <span class="menu-food">Bramborové noky se zelím</span>
                </div>
            </div>
        </div>
    </div>
</div>
