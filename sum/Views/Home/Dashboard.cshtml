@{
    ViewData["Title"] = "Nástěnka";
    var fullName = User.FindFirst("FullName")?.Value ?? User.Identity?.Name ?? "Student";
}

<div class="dashboard-page">
    <div class="dashboard-header animate-in">
        <h1>👋 Ahoj, @fullName!</h1>
        <p>Tady je přehled tvého dne a studia.</p>
    </div>

    <div class="dashboard-grid">
        <div class="dash-card animate-in animate-delay-1">
            <div class="dash-card-header">
                <h3>Průměr známek</h3>
                <div class="dash-card-icon" style="background: rgba(37, 99, 235, 0.15); color: #60a5fa;">
                    <i class="fas fa-chart-line"></i>
                </div>
            </div>
            <div class="value" style="color: #60a5fa;">1.85</div>
            <div class="sub">↓ zlepšení o 0.12 oproti minulému měsíci</div>
        </div>

        <div class="dash-card animate-in animate-delay-2">
            <div class="dash-card-header">
                <h3>Docházka</h3>
                <div class="dash-card-icon" style="background: rgba(16, 185, 129, 0.15); color: #34d399;">
                    <i class="fas fa-check-circle"></i>
                </div>
            </div>
            <div class="value" style="color: #34d399;">96%</div>
            <div class="sub">3 omluvené absence tento měsíc</div>
        </div>

        <div class="dash-card animate-in animate-delay-3">
            <div class="dash-card-header">
                <h3>Úkoly</h3>
                <div class="dash-card-icon" style="background: rgba(245, 158, 11, 0.15); color: #fbbf24;">
                    <i class="fas fa-tasks"></i>
                </div>
            </div>
            <div class="value" style="color: #fbbf24;">4</div>
            <div class="sub">Nesplněných úkolů do konce týdne</div>
        </div>

        <div class="dash-card animate-in animate-delay-4">
            <div class="dash-card-header">
                <h3>Zprávy</h3>
                <div class="dash-card-icon" style="background: rgba(124, 58, 237, 0.15); color: #a78bfa;">
                    <i class="fas fa-envelope"></i>
                </div>
            </div>
            <div class="value" style="color: #a78bfa;">2</div>
            <div class="sub">Nepřečtené zprávy</div>
        </div>
    </div>

    <div class="schedule-card animate-in">
        <h2><i class="fas fa-calendar-day"></i> Dnešní rozvrh</h2>
        <table class="schedule-table">
            <thead>
                <tr>
                    <th>Hodina</th>
                    <th>Čas</th>
                    <th>Předmět</th>
                    <th>Učitel</th>
                    <th>Učebna</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>1.</td>
                    <td>8:00 – 8:45</td>
                    <td><span class="badge-subject badge-math">Matematika</span></td>
                    <td>Mgr. Novák</td>
                    <td>A201</td>
                </tr>
                <tr>
                    <td>2.</td>
                    <td>8:55 – 9:40</td>
                    <td><span class="badge-subject badge-czech">Český jazyk</span></td>
                    <td>PhDr. Dvořáková</td>
                    <td>B105</td>
                </tr>
                <tr>
                    <td>3.</td>
                    <td>9:55 – 10:40</td>
                    <td><span class="badge-subject badge-english">Anglický jazyk</span></td>
                    <td>Mgr. Smith</td>
                    <td>C302</td>
                </tr>
                <tr>
                    <td>4.</td>
                    <td>10:50 – 11:35</td>
                    <td><span class="badge-subject badge-physics">Fyzika</span></td>
                    <td>RNDr. Horák</td>
                    <td>Lab 1</td>
                </tr>
                <tr>
                    <td>5.</td>
                    <td>11:45 – 12:30</td>
                    <td><span class="badge-subject badge-it">Informatika</span></td>
                    <td>Ing. Svoboda</td>
                    <td>PC1</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
